{
    "configurations": [
        {
            "name": "STM32F4",
            "includePath": [
                "${workspaceFolder}/**",
                "${workspaceFolder}/USER",
                "${workspaceFolder}/SYSTEM/delay",
                "${workspaceFolder}/SYSTEM/sys",
                "${workspaceFolder}/SYSTEM/usart",
                "${workspaceFolder}/BSP",
                "${workspaceFolder}/APP",
                "${workspaceFolder}/CORE",
                "${workspaceFolder}/FWLIB/inc",
                "${workspaceFolder}/FWLIB/src",
                "${workspaceFolder}/FreeRTOS/include",
                "${workspaceFolder}/FreeRTOS/portable/RVDS/ARM_CM4F"
            ],
            "defines": [
                "USE_STDPERIPH_DRIVER",
                "STM32F40_41xxx",
                "SYSTEM_SUPPORT_OS",
                "USE_FULL_PRINTF"
            ],
            "compilerPath": "C:/Keil_v5/ARM/ARMCC/bin/armcc.exe",
            "cStandard": "c99",
            "cppStandard": "c++11",
            "intelliSenseMode": "gcc-arm",
            "compilerArgs": [
                "-mcpu=cortex-m4",
                "-mthumb",
                "-mfpu=fpv4-sp-d16",
                "-mfloat-abi=hard"
            ]
        }
    ],
    "version": 4
} 